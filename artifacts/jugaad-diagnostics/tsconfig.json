{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],

  "compilerOptions": {
    "noEmit": true,

    "moduleResolution": "node",
    "module": "commonjs",

    "target": "esnext",
    "lib": ["esnext"],

    "types": ["node"],

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
